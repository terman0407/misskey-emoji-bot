# Copy this file to:
#   .env       → `npm run register` (スラッシュコマンド登録スクリプトが読む)
#   .dev.vars  → `npm run dev` (wrangler dev がローカル secrets として読む)
#
# 本番 Workers のシークレットは `wrangler secret put` か `wrangler secret bulk` で登録してください。

# === Discord ===

# Bot Token (Developer Portal > Bot > Token)
DISCORD_TOKEN=

# Application (Client) ID
# - `npm run register` は DISCORD_CLIENT_ID を、Workers は DISCORD_APPLICATION_ID を読みます。
#   どちらも同じ値です。
DISCORD_CLIENT_ID=
DISCORD_APPLICATION_ID=

# Application Public Key (Developer Portal > General Information > Public Key)
# Workers の Ed25519 署名検証で使います。
DISCORD_PUBLIC_KEY=

# 任意。register 時に指定するとそのギルドだけにスラッシュコマンドを登録 (即時反映)。
# 未指定だとグローバル登録 (反映に最大 1 時間)。
# DISCORD_GUILD_ID=

# 承認可能ロールの ID をカンマ区切り。最低 1 つ必要。
# サーバー設定 > ロール > 右クリックして「ID をコピー」(開発者モード ON 必須)
APPROVER_ROLE_IDS=

# 任意。承認メッセージを投稿する専用チャンネル ID。
# 未指定だと申請が行われた同じチャンネルに投稿します。
DISCORD_APPROVAL_CHANNEL_ID=

# === Misskey ===

# Misskey インスタンスのベース URL (末尾 `/` なし)
# 注: 本番 Workers から到達可能な URL を指定してください (localhost は不可)
MISSKEY_URL=

# Misskey API アクセストークン
# 必要スコープ: write:drive / write:admin:emoji / read:admin:emoji
# 加えて、アカウントには canManageCustomEmojis 権限のあるロールが必要です。
# 発行場所: 設定 > API > アクセストークン発行
MISSKEY_TOKEN=

# 任意。カテゴリ/ライセンス未指定時のデフォルト。
DEFAULT_CATEGORY=
DEFAULT_LICENSE=
