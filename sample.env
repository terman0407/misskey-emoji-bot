# Copy this file to `.env` (手動で作成してください):

# Discord bot token (Developer Portal > Bot > Token)
DISCORD_TOKEN=

# Discord Application (Client) ID — used by `npm run register` for slash commands
DISCORD_CLIENT_ID=


# Misskey instance base URL (no trailing slash)
MISSKEY_URL=

# Misskey API access token with `write:admin:emoji` scope
#   create at: Settings > API > Generate access token
#   the account must have a role with `canManageCustomEmojis`
MISSKEY_TOKEN=

# Optional defaults applied when message body does not specify
DEFAULT_CATEGORY=
DEFAULT_LICENSE=

# Approver Discord role IDs (comma-separated).
# Only members with at least one of these roles can press ✅ / ❌ / ✏️ buttons
# on emoji registration requests.
# If left empty, no one will be able to approve — the bot warns at startup.
# Right-click a role in Server Settings > Roles to copy the ID (developer mode required).
APPROVER_ROLE_IDS=

# Optional. Channel ID where approval messages (with buttons) are posted.
# Recommended: a private channel visible only to approvers.
# If empty, the approval message is posted in the same channel where the
# request was submitted (everyone sees buttons but only approvers can use them).
DISCORD_APPROVAL_CHANNEL_ID=
